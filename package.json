{
  "name": "nexa-live-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "NEXA production streaming starter with auth, payments, live setup, moderation, Prisma, and chat.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma db push && node prisma/seed.js",
    "netlify:build": "node scripts/netlify-build.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "serverless-http": "^3.2.0"
  }
}
